<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Welcome to HRMS – Set Your Password</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  </head>

  <body style="margin: 0; padding: 0; background-color: #f4f6fb">
    <table
      width="100%"
      cellpadding="0"
      cellspacing="0"
      style="background: #f4f6fb"
    >
      <tr>
        <td align="center" style="padding: 24px">
          <!-- OUTER RED -->
          <table
            width="100%"
            cellpadding="0"
            cellspacing="0"
            style="max-width: 640px; background: #f8f8f8; border-radius: 18px"
          >
            <tr>
              <td style="padding: 28px 32px; font-family: Arial, sans-serif">
                <!-- HEADER -->
                <table width="100%" cellpadding="0" cellspacing="0">
                  <tr>
                    <td style="font-size: 22px; font-weight: 800">
                      <img
                        src="{{ companyLogoUrl }}"
                        alt="HRMS Logo"
                        style="width: 100%; max-width: 160px"
                      />
                    </td>
                    <td align="right">
                   <a href="{{linkedinUrl}}" target="_blank" style="width:24px; height:24px; border-radius:4px; text-decoration:none;">
                      <img
                        src="{{ linkedin_logo_url }}"
                        alt="linkedin"
                        style="
                          width: 19.5px;
                          height: 19.5px;
                          margin-right: 10px;
                          display: inline-block;
                        "
                      />
                      </a>
                      <a href="{{instagramUrl}}" target="_blank" style="width:24px; height:24px; border-radius:4px; text-decoration:none;">
                      <img
                        src="{{ instagram_logo_url }}"
                        alt="instagram"
                        style="
                          width: 19.5px;
                          height: 19.5px;
                          margin-right: 10px;
                          display: inline-block;
                        "
                      />
                      </a>
                      <a href="{{twitterUrl}}" target="_blank" style="width:24px; height:24px; border-radius:4px; text-decoration:none;">
                      <img
                        src="{{ x_logo_url }}"
                        alt="x"
                        style="
                          width: 19.5px;
                          height: 19.5px;
                          display: inline-block;
                        "
                      />
                      </a>
                    </td>
                  </tr>
                </table>

                <!-- SPACE -->
                <table width="100%">
                  <tr>
                    <td height="15"></td>
                  </tr>
                </table>

                <!-- ✅ SINGLE GREY CONTAINER -->
                <table
                  width="100%"
                  cellpadding="0"
                  cellspacing="0"
                  style="background: #ffffff; border-radius: 8px"
                >
                  <tr>
                    <td style="padding: 24px">
                      <!-- TITLE -->
                      <table width="100%">
                        <tr>
                          <td style="font-size: 20px; font-weight: 600">
                            Welcome to HRMS 🎉
                          </td>
                        </tr>
                      </table>

                      <!-- SPACE -->
                      <table width="100%">
                        <tr>
                          <td height="12"></td>
                        </tr>
                      </table>

                      <!-- TEXT -->
                      <table width="100%">
                        <tr>
                          <td style="font-size: 16px; color: #656565">
                            Hello <b style="color: #2680d9">{{userName}}</b>,
                          </td>
                        </tr>

                        <tr>
                          <td height="8"></td>
                        </tr>

                        <tr>
                          <td
                            style="
                              font-size: 16px;
                              line-height: 150%;
                              color: #656565;
                            "
                          >
                            Your account has been created successfully. You're
                            one step away from managing your HR operations
                            smarter and faster.
                          </td>
                        </tr>

                        <tr>
                          <td height="8"></td>
                        </tr>

                        <tr>
                          <td style="font-size: 16px; color: #656565">
                            To get started, set your password by clicking the
                            button below:
                          </td>
                        </tr>
                      </table>

                      <!-- SPACE -->
                      <table width="100%">
                        <tr>
                          <td height="16"></td>
                        </tr>
                      </table>

                      <!-- BUTTON -->
                      <table cellpadding="0" cellspacing="0">
                        <tr>
                          <td bgcolor="#2680D9" style="border-radius: 4px">
                            <a
                              href="{{resetUrl}}"
                              target="_blank"
                              style="
                                display: inline-block;
                                padding: 12px 24px;
                                color: #fff;
                                text-decoration: none;
                                font-weight: 500;
                              "
                            >
                              Set Your Password
                            </a>
                          </td>
                        </tr>
                      </table>

                      <!-- SPACE -->
                      <table width="100%">
                        <tr>
                          <td height="20"></td>
                        </tr>
                      </table>

                      <!-- LINK -->
                      <table width="100%">
                        <tr>
                          <td style="font-size: 14px; color: #656565">
                            Or copy this link into your browser:
                          </td>
                        </tr>

                        <tr>
                          <td height="6"></td>
                        </tr>

                        <tr>
                          <td style="font-size: 13px; word-break: break-all">
                            <a href="{{resetUrl}}">{{resetUrl}}</a>
                          </td>
                        </tr>

                        <tr>
                          <td height="6"></td>
                        </tr>

                        <tr>
                          <td style="font-size: 14px; color: #656565">
                            This link expires in 24 hours.
                          </td>
                        </tr>

                        <tr>
                          <td height="6"></td>
                        </tr>

                        <tr>
                          <td
                            style="
                              font-size: 14px;
                              line-height: 150%;
                              color: #656565;
                            "
                          >
                            Have questions? Contact your administrator or reach
                            us at <br />
                            <a href="mailto:support@workconnect.ai"
                              >support@workconnect.ai</a
                            >
                          </td>
                        </tr>
                      </table>
                    </td>
                  </tr>
                </table>

                <!-- SPACE -->
                <table width="100%">
                  <tr>
                    <td height="15"></td>
                  </tr>
                </table>

                <!-- FOOTER -->
                <table width="100%">
                  <tr>
                    <td align="center" style="font-size: 12px; color: #656565">
                      © {{ current_year }} Workconnect.ai · All rights reserved.
                    </td>
                  </tr>

                  <tr>
                    <td height="10"></td>
                  </tr>

                  <tr>
                    <td
                      align="center"
                      style="border-top: 1px solid #dcdcdc"
                    ></td>
                  </tr>

                  <tr>
                    <td height="10"></td>
                  </tr>

                  <tr>
                    <td
                      align="center"
                      style="font-size: 12px; line-height: 150%; color: #656565"
                    >
                      You're receiving this because you're part of
                      {{companyName}} on Workconnect.ai. This is an automated
                      message, please do not reply.
                    </td>
                  </tr>

                  <tr>
                    <td height="8"></td>
                  </tr>

                  <tr>
                    <td align="center">
                      <table cellpadding="0" cellspacing="0" border="0">
                        <tr>
                          <td style="font-size: 12px">
                            <a href="{{ privacyUrl }}" style="color: #2680d9" target="_blank">Privacy Policy</a>
                          </td>

                          <td width="150"></td>
                          <!-- gap -->
                          <td style="font-size: 12px">
                            <a href="{{ termsUrl }}" style="color: #2680d9" target="_blank">Terms of Service</a>
                          </td>

                          <td width="150"></td>
                          <!-- gap -->

                          <td style="font-size: 12px">
                            <a href="{{ unsubscribeUrl }}" style="color: #2680d9" target="_blank">Unsubscribe</a>
                          </td>
                        </tr>
                      </table>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
