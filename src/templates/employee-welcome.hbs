<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Welcome to HRMS – Set Your Password</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
</head>
<body style="margin:0; padding:0; background-color:#f4f6fb;">
  <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="background-color:#f4f6fb;">
    <tr>
      <td align="center" style="padding:24px 16px;">
        <!-- Card wrapper -->
        <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="max-width:640px; background-color:#ffffff; border-radius:18px; box-shadow:0 10px 30px rgba(15,23,42,0.10);">
          <tr>
            <td style="padding:28px 36px 32px 36px; font-family:-apple-system, BlinkMacSystemFont, 'Segoe UI', Arial, sans-serif; color:#111827;">
              <!-- Header row -->
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0">
                <tr>
                  <td align="left" valign="middle">
                    <!-- Logo text -->
                    <span style="font-size:22px; font-weight:800; color:#111827;">
                      <img src="{{ companyLogoUrl }}" alt="{{ companyName }} Logo" width="176" style="vertical-align:middle; margin-right:8px;" />
                    </span>
                  </td>
                  <td align="right" valign="middle">
                    <!-- Social icons -->
                    <table role="presentation" cellspacing="0" cellpadding="0" border="0">
                      <tr>
                        <td style="padding-left:10px;">
                          <a href="{{ linkedinUrl }}"
                             style="display:inline-flex; align-items:center; justify-content:center; width:24px; height:24px; border-radius:4px; text-decoration:none; background-color:transparent; border:none;">
                            <!-- LinkedIn icon -->
                            <img src="{{ linkedin_logo_url }}" alt="LinkedIn" width="20" height="20" style="display:block;">
                          </a>
                        </td>
                        <td style="padding-left:10px;">
                          <a href="{{ instagramUrl }}"
                             style="display:inline-flex; align-items:center; justify-content:center; width:24px; height:24px; border-radius:4px; text-decoration:none; background-color:transparent; border:none;">
                            <!-- Instagram icon -->
                            <img src="{{ instagram_logo_url }}" alt="Instagram" width="20" height="20" style="display:block;">
                          </a>
                        </td>
                        <td style="padding-left:10px;">
                          <a href="{{ twitterUrl }}"
                             style="display:inline-flex; align-items:center; justify-content:center; width:24px; height:24px; border-radius:4px; text-decoration:none; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Arial,sans-serif; font-size:15px; font-weight:600; color:#111827;">
                            <!-- X icon -->
                            <img src="{{ x_logo_url }}" alt="X" width="20" height="20" style="display:block;">
                          </a>
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>

              <!-- Spacing -->
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0">
                <tr><td style="height:28px; line-height:28px; font-size:0;">&nbsp;</td></tr>
              </table>

              <!-- Title -->
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0">
                <tr>
                  <td>
                    <p style="margin:0 0 16px 0; font-size:24px; line-height:32px; font-weight:700; color:#111827;">
                      Welcome to HRMS 🎉
                    </p>
                  </td>
                </tr>
              </table>

              <!-- Greeting + intro -->
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0">
                <tr>
                  <td style="font-size:15px; line-height:24px; color:#4b5563;">
                    <p style="margin:0 0 8px 0;">
                      Hello <span style="font-weight:600;">{{userName}}</span>,
                    </p>
                    <p style="margin:0 0 8px 0;">
                      Your account has been created successfully. You're one step away from managing your HR operations smarter and faster.
                    </p>
                    <p style="margin:0 0 20px 0;">
                      To get started, set your password by clicking the button below:
                    </p>
                  </td>
                </tr>
              </table>

              <!-- Primary button -->
              <table role="presentation" cellspacing="0" cellpadding="0" border="0" align="start">
                <tr>
                  <td align="center" bgcolor="#1976d2" style="border-radius:4px;">
                    <a href="{{resetUrl}}" target="_blank"
                       style="display:inline-block; padding:14px 32px; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Arial,sans-serif; font-size:15px; font-weight:600; color:#ffffff; text-decoration:none; border-radius:10px;">
                      Set Your Password
                    </a>
                  </td>
                </tr>
              </table>

              <!-- Spacing -->
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0">
                <tr><td style="height:24px; line-height:24px; font-size:0;">&nbsp;</td></tr>
              </table>

              <!-- Fallback link and info -->
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0">
                <tr>
                  <td style="font-size:13px; line-height:20px; color:#6b7280;">
                    <p style="margin:0 0 10px 0;">
                      Or copy this link into your browser:
                    </p>
                    <p style="margin:0 0 10px 0; word-break:break-all;">
                      <a href="{{resetUrl}}" style="color:#2563eb; text-decoration:underline;">
                        {{resetUrl}}
                      </a>
                    </p>
                    <p style="margin:0 0 8px 0;">
                      This link expires in <span style="font-weight:600;">24 hours</span>.
                    </p>
                    <p style="margin:0 0 0 0;">
                      Have questions? Contact your administrator or reach us at
                      <a href="mailto:support@workconnect.ai" style="color:#2563eb; text-decoration:underline;">support@workconnect.ai</a>
                    </p>
                  </td>
                </tr>
              </table>

              <!-- Spacing before copyright -->
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0">
                <tr><td style="height:32px; line-height:32px; font-size:0;">&nbsp;</td></tr>
              </table>

              <!-- Copyright -->
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0">
                <tr>
                  <td style="font-size:12px; line-height:18px; color:#9ca3af; text-align:center;">
                    <p style="margin:0 0 6px 0;">
                      © {{ current_year }} Workconnect.ai · All rights reserved.
                    </p>
                  </td>
                </tr>
              </table>

              <!-- Small spacing -->
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0">
                <tr><td style="height:2px; line-height:1px; font-size:0;">&nbsp;</td></tr>
              </table>

              <!-- Divider -->
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0">
                <tr>
                  <td style="border-top:1px solid #e5e7eb; font-size:0; line-height:0;">&nbsp;</td>
                </tr>
              </table>

              <!-- Spacing after divider -->
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0">
                <tr><td style="height:12px; line-height:12px; font-size:0;">&nbsp;</td></tr>
              </table>

              <!-- Footer text + links -->
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0">
                <tr>
                  <td style="font-size:12px; line-height:18px; color:#9ca3af; text-align:center;">
                    <p style="margin:0 0 14px 0;">
                      You're receiving this because you're part of {{companyName}} on Workconnect.ai. This is an automated message, please do not reply.
                    </p>
                  </td>
                </tr>
                <tr>
                  <td align="center" style="font-size:12px; line-height:18px; color:#6b7280;">
                    <a href="{{ privacyUrl }}" style="color:#1976d2; text-decoration:underline; margin:0 8px;">Privacy Policy</a>
                    <a href="{{ termsUrl }}" style="color:#1976d2; text-decoration:underline; margin:0 8px;">Terms of Service</a>
                    <a href="{{ unsubscribeUrl }}" style="color:#1976d2; text-decoration:underline; margin:0 8px;">Unsubscribe</a>
                  </td>
                </tr>
              </table>

            </td>
          </tr>
        </table>
        <!-- /Card wrapper -->
      </td>
    </tr>
  </table>
</body>
</html>