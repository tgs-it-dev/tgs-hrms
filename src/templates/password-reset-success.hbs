<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Password Reset Successful</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
</head>
<body style="margin:0; padding:0; background-color:#f4f6fb;">
  <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="background-color:#f4f6fb;">
    <tr>
      <td align="center" style="padding:24px;">
        <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="max-width:640px; background:#f8f8f8; border-radius:18px;">
          <tr>
            <td style="padding:28px 32px; font-family:Arial, sans-serif;">
              <!-- Header -->
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0">
                <tr>
                  <td style="font-size:22px; font-weight:800;">
                    <img src="{{ companyLogoUrl }}" alt="HRMS Logo" style="width:100%; max-width:160px; display:block; border:0;" />
                  </td>
                  <td align="right" valign="middle">
                    <a href="{{linkedinUrl}}" style="width:24px; height:24px; border-radius:4px; text-decoration:none;">
                      <img src="{{ linkedin_logo_url }}" alt="LinkedIn" style="width:19.5px; height:19.5px; margin-right:10px; display:inline-block; border:0;" />
                    </a>
                    <a href="{{instagramUrl}}" style="width:24px; height:24px; border-radius:4px; text-decoration:none;">
                      <img src="{{ instagram_logo_url }}" alt="Instagram" style="width:19.5px; height:19.5px; margin-right:8px; display:inline-block; border:0;" />
                    </a>
                    <a href="{{twitterUrl}}" style="width:24px; height:24px; border-radius:4px; text-decoration:none;">
                      <img src="{{ x_logo_url }}" alt="X" style="width:19.5px; height:19.5px; display:inline-block; border:0;" />
                    </a>
                  </td>
                </tr>
              </table>

              <table role="presentation" width="100%"><tr><td style="height:15px; line-height:15px; font-size:0;">&nbsp;</td></tr></table>

              <!-- Inner white card -->
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="background:#ffffff; border-radius:8px;">
                <tr>
                  <td style="padding:24px;">
                    <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0">
                      <tr>
                        <td style="font-size:20px; font-weight:600; color:#111827;">Password Reset Successful</td>
                      </tr>
                    </table>

                    <table role="presentation" width="100%"><tr><td style="height:12px; line-height:12px; font-size:0;">&nbsp;</td></tr></table>

                    <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0">
                      <tr>
                        <td style="font-size:16px; color:#656565;">
                          Hello <b style="color:#2680d9;">{{ userName }}</b>,
                        </td>
                      </tr>
                      <tr><td style="height:8px; line-height:8px; font-size:0;">&nbsp;</td></tr>
                      <tr>
                        <td style="font-size:16px; line-height:150%; color:#656565;">
                          Your password has been successfully reset. You can now log in to your account with your new password.
                        </td>
                      </tr>
                      <tr><td style="height:8px; line-height:8px; font-size:0;">&nbsp;</td></tr>
                      <tr>
                        <td style="font-size:16px; color:#656565;">Use the button below to go to the login page:</td>
                      </tr>
                    </table>

                    <table role="presentation" width="100%"><tr><td style="height:16px; line-height:16px; font-size:0;">&nbsp;</td></tr></table>

                    <table role="presentation" cellspacing="0" cellpadding="0" border="0">
                      <tr>
                        <td bgcolor="#2680D9" style="border-radius:4px;">
                          <a href="{{ loginUrl }}" style="display:inline-block; padding:12px 24px; color:#fff; text-decoration:none; font-weight:500; font-size:16px;">Go To Login</a>
                        </td>
                      </tr>
                    </table>

                    <table role="presentation" width="100%"><tr><td style="height:20px; line-height:20px; font-size:0;">&nbsp;</td></tr></table>

                    <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0">
                      <tr>
                        <td style="font-size:14px; line-height:150%; color:#656565;">
                          If you did not make this change, your account may be compromised. Contact our support team immediately.
                        </td>
                      </tr>
                      <tr><td style="height:10px; line-height:10px; font-size:0;">&nbsp;</td></tr>
                      <tr>
                        <td style="font-size:14px; color:#656565; line-height: 150%;">
                          Have questions? Contact your administrator or reach us at<br />
                          <a href="mailto:support@workconnect.ai" style="color:#2680d9;">support@workconnect.ai</a>
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>

              <table role="presentation" width="100%"><tr><td style="height:15px; line-height:15px; font-size:0;">&nbsp;</td></tr></table>

              <!-- Footer -->
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0">
                <tr>
                  <td align="center" style="font-size:12px; color:#656565;">© {{ current_year }} Workconnect.ai · All rights reserved.</td>
                </tr>
                <tr><td style="height:10px; line-height:10px; font-size:0;">&nbsp;</td></tr>
                <tr>
                  <td align="center" style="border-top:1px solid #dcdcdc; font-size:0; line-height:0;">&nbsp;</td>
                </tr>
                <tr><td style="height:10px; line-height:10px; font-size:0;">&nbsp;</td></tr>
                <tr>
                  <td align="center" style="font-size:12px; line-height:150%; color:#656565;">
                    You're receiving this because you're part of {{ companyName }} on Workconnect.ai. This is an automated message, please do not reply.
                  </td>
                </tr>
                <tr><td style="height:8px; line-height:8px; font-size:0;">&nbsp;</td></tr>
                <tr>
                  <td align="center">
                    <table role="presentation" cellpadding="0" cellspacing="0" border="0">
                      <tr>
                        <td style="font-size:12px;"><a href="{{ privacyPolicyUrl }}" style="color:#2680d9;">Privacy Policy</a></td>
                        <td width="150"></td>
                        <td style="font-size:12px;"><a href="{{ termsUrl }}" style="color:#2680d9;">Terms of Service</a></td>
                        <td width="150"></td>
                        <td style="font-size:12px;"><a href="{{ unsubscribeUrl }}" style="color:#2680d9;">Unsubscribe</a></td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>